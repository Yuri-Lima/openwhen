# Copy to .env for local emulator testing (not committed).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PRO=price_...

# AI moderation (callable `moderateContent`)
OPENAI_API_KEY=sk-...
# Optional; default is openai when unset.
MODERATION_PROVIDER=openai

# External letter invite email (`onLetterCreatedSendExternalInviteEmail` — Twilio SendGrid REST API)
# SENDGRID_API_KEY is managed via Firebase Secret Manager (defineSecret).
# To set/update: firebase functions:secrets:set SENDGRID_API_KEY
# Optional; must be a verified sender in SendGrid. Defaults to noreply@whenote.app in code.
SENDGRID_FROM_EMAIL=noreply@whenote.app
# Optional; display name in the inbox. Defaults to Whenote in code.
SENDGRID_FROM_NAME=Whenote
