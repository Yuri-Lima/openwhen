# Copy to .env for local emulator testing (not committed).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PRO=price_...

# AI moderation (callable `moderateContent`)
OPENAI_API_KEY=sk-...
# Optional; default is openai when unset.
MODERATION_PROVIDER=openai

# External letter invite email (`onLetterCreatedSendExternalInviteEmail` — Twilio SendGrid REST API)
# If SENDGRID_API_KEY is unset, invite emails are skipped (claim still works).
SENDGRID_API_KEY=SG....
# Optional; must be a verified sender in SendGrid. Defaults to noreply@openwhen.app in code.
SENDGRID_FROM_EMAIL=noreply@openwhen.app
# Optional; display name in the inbox. Defaults to OpenWhen in code.
SENDGRID_FROM_NAME=OpenWhen
