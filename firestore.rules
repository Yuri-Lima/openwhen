rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    // Billing fields are written only by backend (Stripe webhooks). Client may set subscriptionTier to free once if missing.
    // Use .get(..., null) so missing keys compare equal to explicit nulls after merges/updates.
    function userBillingFieldsUnchanged() {
      return request.resource.data.get('subscriptionTier', null) == resource.data.get('subscriptionTier', null)
        && request.resource.data.get('stripeCustomerId', null) == resource.data.get('stripeCustomerId', null)
        && request.resource.data.get('stripeSubscriptionId', null) == resource.data.get('stripeSubscriptionId', null)
        && request.resource.data.get('subscriptionStatus', null) == resource.data.get('subscriptionStatus', null);
    }

    function userBillingOnlyFreeTierMigration() {
      return resource.data.get('subscriptionTier', null) == null
        && request.resource.data.subscriptionTier == 'free'
        && request.resource.data.get('stripeCustomerId', null) == resource.data.get('stripeCustomerId', null)
        && request.resource.data.get('stripeSubscriptionId', null) == resource.data.get('stripeSubscriptionId', null)
        && request.resource.data.get('subscriptionStatus', null) == resource.data.get('subscriptionStatus', null);
    }

    function userCreateHasNoServerBillingFields() {
      return !request.resource.data.keys().hasAny(['stripeCustomerId', 'stripeSubscriptionId', 'subscriptionStatus']);
    }

    // Perfis
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isUser(userId)
        && request.resource.data.subscriptionTier == 'free'
        && userCreateHasNoServerBillingFields();
      allow update: if isUser(userId) && (
        userBillingFieldsUnchanged() || userBillingOnlyFreeTierMigration()
      );
      allow delete: if isUser(userId);

      // Conquistas — apenas criação pelo próprio utilizador; ids fixos (anti-fraude leve)
      match /badgeUnlocks/{badgeId} {
        allow read: if signedIn();
        allow create: if isUser(userId)
          && badgeId in [
            'first_letter_sent',
            'first_letter_opened',
            'first_public',
            'letters_sent_five',
            'letters_sent_ten',
            'voice_letter'
          ]
          && request.resource.data.keys().hasOnly(['unlockedAt'])
          && (
            request.resource.data.unlockedAt == request.time
            || request.resource.data.unlockedAt is timestamp
          );
        allow update, delete: if false;
      }

      // Notificações (moderação, etc.) — escrita só Cloud Functions / Admin SDK
      match /notifications/{notifId} {
        allow read: if isUser(userId);
        allow update: if isUser(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
          && request.resource.data.read == true;
        allow create, delete: if false;
      }
    }

    // Cartas
    match /letters/{letterId} {
      allow read: if signedIn() && (
        resource.data.senderUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid ||
        (resource.data.isPublic == true && resource.data.status == 'opened')
      );
      allow create: if signedIn() && emailVerified() && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if signedIn() && (
        resource.data.senderUid == request.auth.uid ||
        resource.data.receiverUid == request.auth.uid
      );
    }

    function capsuleParticipantRead() {
      return resource.data.keys().hasAny(['participantUids'])
        && request.auth.uid in resource.data.participantUids;
    }

    function capsuleLegacyRead() {
      return resource.data.senderUid == request.auth.uid
        || resource.data.receiverUid == request.auth.uid;
    }

    function capsuleParticipantUpdateFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'openedAt', 'isPublic', 'publishedAt']);
    }

    // Cápsulas
    match /capsules/{capsuleId} {
      allow read: if signedIn() && (
        capsuleLegacyRead() ||
        capsuleParticipantRead() ||
        (resource.data.isPublic == true && resource.data.status == 'opened')
      );
      allow create: if signedIn() && emailVerified()
        && request.resource.data.senderUid == request.auth.uid
        && (
          !request.resource.data.keys().hasAny(['participantUids'])
          || (
            request.resource.data.participantUids is list
            && request.auth.uid in request.resource.data.participantUids
            && request.resource.data.participantUids.size() >= 1
            && request.resource.data.participantUids.size() <= 20
            && (!request.resource.data.keys().hasAny(['contentMode'])
              || request.resource.data.contentMode == 'singleAuthor')
          )
        );
      allow update: if signedIn() && (
        resource.data.senderUid == request.auth.uid
        || (
          resource.data.keys().hasAny(['participantUids'])
          && request.auth.uid in resource.data.participantUids
          && capsuleParticipantUpdateFieldsOnly()
        )
      );
      allow delete: if signedIn() && resource.data.senderUid == request.auth.uid;

      // Futuro: contribuições por participante (multiContributor). Escrita desligada no cliente até essa fase.
      match /contributions/{contributorUid} {
        allow read: if signedIn() && (
          get(/databases/$(database)/documents/capsules/$(capsuleId)).data.senderUid == request.auth.uid
          || get(/databases/$(database)/documents/capsules/$(capsuleId)).data.receiverUid == request.auth.uid
          || (
            get(/databases/$(database)/documents/capsules/$(capsuleId)).data.keys().hasAny(['participantUids'])
            && request.auth.uid in get(/databases/$(database)/documents/capsules/$(capsuleId)).data.participantUids
          )
        );
        allow create, update, delete: if false;
      }
    }

    // Comentários
    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn() && emailVerified() && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userUid == request.auth.uid;
    }

    // Curtidas
    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.userUid == request.auth.uid;
      allow update: if false;
    }

    // Seguidores
    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // Bloqueios
    match /blocks/{blockId} {
      allow read: if signedIn() && resource.data.blockedBy == request.auth.uid;
      allow create: if signedIn() && request.resource.data.blockedBy == request.auth.uid;
      allow delete: if signedIn() && resource.data.blockedBy == request.auth.uid;
      allow update: if false;
    }

    // Denúncias — schema fixo; moderação via Admin SDK / Cloud Functions
    match /reports/{reportId} {
      allow read: if false;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'reporterUid', 'targetType', 'targetId', 'letterId', 'reason', 'detail', 'status', 'createdAt'
        ])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetType in ['letter', 'comment']
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() >= 1
        && request.resource.data.targetId.size() <= 128
        && request.resource.data.letterId is string
        && request.resource.data.letterId.size() >= 1
        && request.resource.data.letterId.size() <= 128
        && request.resource.data.reason in ['spam', 'harassment', 'hate', 'illegal', 'other']
        && request.resource.data.detail is string
        && request.resource.data.detail.size() <= 2000
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    // Incidentes de moderação (IA / ops) — só Admin SDK / Cloud Functions
    match /moderationIncidents/{incidentId} {
      allow read, write: if false;
    }

    // Fila de revisão humana — só Admin SDK / Cloud Functions
    match /moderationReviews/{reviewId} {
      allow read, write: if false;
    }

    // Config remota legível por utilizadores autenticados (escrita só Admin SDK / Functions)
    match /systemConfig/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Log de ações de privacidade (export, deleção, anonimização) — create-only, schema fixo
    match /privacyRequestLogs/{logId} {
      allow read: if false;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['uid', 'type', 'status', 'metadata', 'createdAt', 'source'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type in ['export']
        && request.resource.data.status in ['completed', 'failed']
        && request.resource.data.metadata is map
        && request.resource.data.createdAt == request.time
        && request.resource.data.source == 'client';
      allow update, delete: if false;
    }

    // Feedback / solicitações de produto (somente criação; schema fixo)
    match /feedback/{feedbackId} {
      allow read: if false;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['uid', 'type', 'message', 'createdAt', 'appLocale', 'platform'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type in ['feature', 'recommendation', 'general']
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 4000
        && request.resource.data.createdAt == request.time
        && request.resource.data.appLocale is string
        && request.resource.data.appLocale.size() <= 32
        && request.resource.data.platform is string
        && request.resource.data.platform.size() <= 32;
      allow update, delete: if false;
    }
  }
}
